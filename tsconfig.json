{
  "compilerOptions": {
    "target": "ES2022", "module": "ESNext", "jsx": "react-jsx",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@services": ["../../packages/services/index.ts"],
      "@services/*": ["../../packages/services/*"],
      "@ui/*": ["../../packages/ui/*"],
      "@assets/*": ["../../assets/*"]
    },
    "resolveJsonModule": true,
    "strict": true, "skipLibCheck": true
  },
  "include": ["src"]
}